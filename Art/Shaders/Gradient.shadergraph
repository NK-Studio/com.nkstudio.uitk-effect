{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "bd568a37d2c24e4182578645400fc551",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "NormalizeProjection (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -175.99998474121095,
            "y": -427.9999694824219,
            "width": 269.33331298828127,
            "height": 304.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "e93f14a5df3447ae96b65cf5bed600af"
        },
        {
            "m_Id": "f1e3cb5695a5412ea7e617966f77acbd"
        },
        {
            "m_Id": "10244590010a4187894e869f3db693da"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "NormalizeProjection",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 projectionMinUV = float2(direction.x < 0.0 ? 1.0 : 0.0,\r\n                                                direction.y < 0.0 ? 1.0 : 0.0);\r\nfloat2 projectionMaxUV = 1.0 - projectionMinUV;\r\nfloat projectionMin = dot(projectionMinUV, direction);\r\nfloat projectionMax = dot(projectionMaxUV, direction);\r\nt = saturate((dot(uv, direction) - projectionMin)/ max(projectionMax - projectionMin, 0.0001));"
}

